# Copy to .env and fill in. Never commit your real .env.

NODE_ENV=development
PORT=3000

# Matches docker-compose.yml credentials.
DATABASE_URL=postgres://scrobbler:scrobbler@localhost:5432/scrobbler

# From your Spotify Developer Dashboard app.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# Must EXACTLY match a Redirect URI registered in the dashboard.
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback/spotify

# Worker tuning (optional; defaults shown).
POLL_INTERVAL_SECONDS=60
POLL_BATCH_SIZE=25
